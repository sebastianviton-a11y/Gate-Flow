{
  "name": "gateflow",
  "private": true,
  "version": "0.1.0",
  "description": "GateFlow — plataforma SaaS multi-tenant de operaciones de portería. Monorepo.",
  "scripts": {
    "dev": "concurrently -n admin,guard -c blue,magenta \"pnpm dev:admin\" \"pnpm dev:guard\"",
    "dev:admin": "pnpm --filter @gateflow/admin dev",
    "dev:guard": "pnpm --filter @gateflow/guard dev",
    "build": "pnpm build:admin && pnpm build:guard",
    "build:admin": "pnpm --filter @gateflow/admin build",
    "build:guard": "pnpm --filter @gateflow/guard build",
    "lint": "pnpm lint:admin && pnpm lint:guard",
    "lint:admin": "pnpm --filter @gateflow/admin lint",
    "lint:guard": "pnpm --filter @gateflow/guard lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
