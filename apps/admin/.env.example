# Copiar a .env.local y completar con los valores del proyecto Supabase de GateFlow.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL pública real del sitio de apps/guard en Netlify — no de este sitio
# (admin). El QR de retiro siempre apunta a la app de guardia, sin
# importar desde cuál de las dos apps se registró el paquete. Ver la
# misma variable documentada en apps/guard/.env.example.
NEXT_PUBLIC_GUARD_APP_URL=https://tu-sitio-guard.netlify.app
